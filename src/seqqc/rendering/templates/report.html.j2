<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>seqqc — {{ result.filename }}</title>
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>
  <style>
    body {
      font-family: system-ui, sans-serif;
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem;
      color: #1a1a1a;
    }
    h1 { font-size: 1.4rem; font-weight: 600; margin-bottom: 0.25rem; }
    .meta { color: #666; font-size: 0.9rem; margin-bottom: 2rem; }
    .plot { margin-bottom: 2rem; }
  </style>
</head>
<body>
  <h1>QC Report</h1>
  <p class="meta">
    File: <strong>{{ result.filename }}</strong>
    {% if result.read_count %}
      &nbsp;·&nbsp; Reads: <strong>{{ result.read_count.value | int }}</strong>
    {% endif %}
  </p>

  {% for plot in plots %}
    <div class="plot">{{ plot | safe }}</div>
  {% endfor %}
</body>
</html>